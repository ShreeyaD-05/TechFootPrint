# ── Supabase (recommended) ────────────────────────────────────────────────────
#
# Get both strings from:
#   Supabase Dashboard → Project Settings → Database → Connection string
#
# DATABASE_URL  — Pooled (Transaction mode, port 6543)
#   Used by the FastAPI app at runtime.  PgBouncer manages the pool.
#
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
#
# DIRECT_URL  — Direct (Session mode, port 5432)
#   Used ONLY by Alembic migrations.  PgBouncer transaction mode does not
#   support DDL statements or prepared statements needed by Alembic.
#
DIRECT_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# ── Local PostgreSQL (alternative for local dev) ──────────────────────────────
# Uncomment and comment out the Supabase lines above to use local Postgres.
# DATABASE_URL=postgresql://postgres:123@localhost:5432/devanalytics
# DIRECT_URL=postgresql://postgres:123@localhost:5432/devanalytics

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Other services ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── Email (SMTP / nodemailer-style) ───────────────────────────────────────────
# Set EMAIL_ENABLED=true and fill in credentials to send real emails.
# When EMAIL_ENABLED=false (default), emails are logged but not sent.
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=CodeTrack Platform
SMTP_FROM_EMAIL=your-email@gmail.com
# For Gmail: use an App Password (not your account password).
# Enable 2FA → Google Account → Security → App Passwords → Generate.
